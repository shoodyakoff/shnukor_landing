# Upstream sneakers catalog API — target of the server-side /api/sneakers proxy.
SNEAKERS_API_URL=https://shnurok-shipping.ru/api/sneakers.php

# Private token for the upstream API. Injected server-side only — it is NEVER
# shipped to the browser or baked into the image. Keep it out of git; set it on
# the server (this .env is read by docker compose at runtime).
SNEAKERS_API_TOKEN=

# Public origin for SEO/social meta tags, robots.txt and sitemap.xml.
# Used at BUILD time (docker compose passes it as a build arg). Leave blank to
# keep the default origin. Example: https://shnurok.ru
VITE_SITE_URL=
